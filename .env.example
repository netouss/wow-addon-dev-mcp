# wow-addon-dev-mcp — Environment Variables
# Copy this file to .env and fill in your paths.
# .env is git-ignored and never committed.

# Path to a local clone of https://github.com/Gethe/wow-ui-source
# Required for: lookup_blizzard_api, search_blizzard_api, get_api_namespace,
#               get_api_events, search_framexml, get_blizzard_addon,
#               get_wow_constants, get_widget_api
# Leave empty if you don't have a local clone — other tools still work.
WOW_UI_SOURCE_PATH=/path/to/wow-ui-source

# Path to your local WoW addons workspace (optional)
# Only used by scaffold_addon to suggest file output paths.
ADDONS_WORKSPACE_PATH=/path/to/your/addons
